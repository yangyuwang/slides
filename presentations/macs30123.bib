@article{risamMarginsIntersectionalityDigital2015,
	title = {Beyond the Margins: Intersectionality and the Digital Humanities},
	volume = {9},
	rights = {Creative Commons Attribution-{NoDerivatives} 4.0 International License},
	issn = {1938-4122},
	url = {https://www.digitalhumanities.org/dhq/vol/9/2/000208/000208.html},
	shorttitle = {Beyond the Margins},
	abstract = {This article examines the relationship between intersectionality and the digital humanities. Intersectionality offers a critical approach to debates between theory and method in the field, transcending simplistic hack vs. yack binaries. This article situates debates over difference in the digital humanities within the context of the culture wars within the U.S. academy during the 1980s and 1990s, locating the stakes for diversity in the digital humanities. It surveys digital humanities projects, outlining the need for alternate histories of the digital humanities told through intersectional lenses. Finally, the article proposes ways of looking forward towards the deeper intersectional analysis needed to expand intellectual diversity in the field and move difference beyond the margins of the digital humanities.},
	number = {2},
	journaltitle = {Digital Humanities Quarterly},
	author = {Risam, Roopika},
	urldate = {2025-05-28},
	date = {2015},
	keywords = {⛔ No {DOI} found},
}

